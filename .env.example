APP_ENV=development
APP_NAME=CRE Investment AI Platform

POSTGRES_DB=cre_ai
POSTGRES_USER=cre_ai
POSTGRES_PASSWORD=cre_ai_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://cre_ai:cre_ai_password@db:5432/cre_ai

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

COLLECTION_INTERVAL_MINUTES=30
MIN_PRICE_RUB=100000000
MAX_PRICE_RUB=400000000
MIN_BUILDING_YEAR=2016
ALLOWED_FLOOR=1
ALLOWED_PROPERTY_TYPES=street_retail,retail,free_use,federal_tenant

